# ─────────────────────────────────────────────────────────────────────────────
# Environment selection
#
# Determines which base URL is used for the test run.
# Allowed values: local | staging | production
#
# Priority (highest → lowest):
#   1. This variable set in the shell:  TEST_ENV=staging npx playwright test
#   2. Value set in this file (.env)
#   3. "defaultEnvironment" in config/env.config.json  (currently "local")
# ─────────────────────────────────────────────────────────────────────────────
TEST_ENV=local
